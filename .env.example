# PostgreSQL
POSTGRES_URL=jdbc:postgresql://localhost:5432/vietrecruit
POSTGRES_DB=vietrecruit
POSTGRES_USER=vietrecruit
POSTGRES_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
ACCESS_TOKEN_TTL=PT15M
REFRESH_TOKEN_TTL=P30D
JWT_ISSUER=auth-service

# Server & App
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
APP_BASE_URL=http://localhost:8080

# Mail (uncomment when spring-boot-starter-mail dep is active)
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=

# Docker
DOCKER_USERNAME=
DOCKER_APP=vietrecruit
DOCKER_APP_VERSION=latest

# Kafka (uncomment when spring-kafka dep is active)
# KAFKA_BOOTSTRAP_SERVERS=localhost:29092
