# PostgreSQL
POSTGRES_URL=jdbc:postgresql://localhost:5432/vietrecruit
POSTGRES_DB=vietrecruit
POSTGRES_USER=vietrecruit
POSTGRES_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
ACCESS_TOKEN_TTL=PT15M
REFRESH_TOKEN_TTL=P30D
JWT_ISSUER=auth-service

# Server & App
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
APP_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=https://vietrecruit.site

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Kafka UI (required for prod auth — docker-compose.prod.yml lines 160-161)
KAFKA_UI_USERNAME=
KAFKA_UI_PASSWORD=

# Grafana
GRAFANA_PASSWORD=

# Loki
LOKI_URL=http://localhost:3100/loki/api/v1/push

# Elasticsearch
ELASTICSEARCH_URI=http://localhost:9200

# AI Configuration
# Dev default: gpt-4o-mini / text-embedding-3-small (1536 dims)
# Prod: override via environment or secrets manager
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Resend (Email API)
RESEND_API_KEY=

# Docker
DOCKER_USERNAME=
DOCKER_APP=vietrecruit
DOCKER_APP_VERSION=latest

# Oauth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Admin Seeder
ADMIN_EMAIL=admin@vietrecruit.site
ADMIN_PASSWORD=admin

# PayOS
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_LOG_LEVEL=NONE
PAYOS_RETURN_URL=http://localhost:3000/payment/success
PAYOS_CANCEL_URL=http://localhost:3000/payment/cancel

# Cloudflare R2 (S3-compatible storage)
R2_ENDPOINT=
R2_BUCKET=vietrecruit
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_PUBLIC_URL=


